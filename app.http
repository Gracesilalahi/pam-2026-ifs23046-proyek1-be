## ========================================================================
## GLOBAL VARIABLES
## ========================================================================
# Gunakan localhost untuk testing di laptop (paling stabil sekarang)
#@BaseUrl = http://localhost:8080

# Gunakan ini kalau deployment s1if.life kamu sudah tidak 502 lagi
@BaseUrl = https://pam-2026-ifs23046-proyek1-be.s1if.life:8080/

### -----------------------------------------------------------------------
## 1. AUTHENTICATION (Pintu Masuk)
### -----------------------------------------------------------------------

### A. Register - Buat akun baru
# @name PostRegister
POST {{BaseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Grace",
  "username": "m",
  "password": "password123"
}

### B. Login - Ambil Token JWT
# @name PostLogin
POST {{BaseUrl}}/auth/login
Content-Type: application/json

{
  "username": "m",
  "password": "password123"
}

> {%
    // Penting: Kita simpan token ke memori HTTP Client biar gak copy-paste manual
    client.global.set("authToken", response.body.data.token);
    client.global.set("refreshToken", response.body.data.refreshToken);
%}

### C. Refresh Token - Jika token sudah expired
# @name PostRefreshToken
POST {{BaseUrl}}/auth/refresh-token
Content-Type: application/json

{
  "token": "{{authToken}}",
  "refreshToken": "{{refreshToken}}"
}

### -----------------------------------------------------------------------
## 2. USERS (Profil Pengguna)
### -----------------------------------------------------------------------

### A. Get My Profile
# @name GetUserMe
GET {{BaseUrl}}/users/me
Authorization: Bearer {{authToken}}
Content-Type: application/json

> {%
    // Simpan userId buat testing filter atau detail nanti
    client.global.set("userId", response.body.data.user.id);
%}

### B. Update Profile
# @name PutUserMe
PUT {{BaseUrl}}/users/me
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "Grace Silalahi (Informatics Del)",
  "username": "j",
  "about": "Mahasiswi semester 6 yang akhirnya sukses build Ktor!"
}

### -----------------------------------------------------------------------
## 3. WARDROBE (Core CRUD - Poin Utama Proyek)
### -----------------------------------------------------------------------

### A. Create - Tambah Baju Baru
# @name PostWardrobe
POST {{BaseUrl}}/wardrobe
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "Kemeja Flanel Biru",
  "category": "TOP",
  "color": "Biru Kotak-kotak",
  "description": "Baju favorit buat praktikum PAM di lab"
}

> {%
    // Simpan itemId baju yang baru dibuat buat ngetes Detail/Delete
    client.global.set("itemId", response.body.data.id);
%}

### B. Read - Ambil Daftar Baju (Pagination & Search)
# page: 1, perPage: 10, search: cari nama, category: TOP/BOTTOM/SHOES
# @name GetWardrobes
GET {{BaseUrl}}/wardrobe?page=1&perPage=10&search=&category=&sortBy=createdAt&order=desc
Authorization: Bearer {{authToken}}
Content-Type: application/json

### C. Read - Ambil Detail Satu Baju
# @name GetWardrobeById
GET {{BaseUrl}}/wardrobe/{{itemId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

### D. Update - Edit Data Baju
# @name PutWardrobe
PUT {{BaseUrl}}/wardrobe/{{itemId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "Kemeja Flanel Biru Del",
  "category": "TOP",
  "color": "Navy",
  "description": "Sudah diupdate datanya"
}

### E. Delete - Hapus Baju dari Lemari
# @name DeleteWardrobe
DELETE {{BaseUrl}}/wardrobe/{{itemId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

### -----------------------------------------------------------------------
## 4. STATIC IMAGES
### -----------------------------------------------------------------------

### Mengambil Gambar Baju
GET {{BaseUrl}}/images/wardrobe/{{itemId}}
Authorization: Bearer {{authToken}}